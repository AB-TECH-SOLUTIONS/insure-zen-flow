# ============================================================================
# InsureZen Flow — Exemple de variables d'environnement
# ----------------------------------------------------------------------------
# ⚠️  NE JAMAIS commiter de vraies valeurs dans ce fichier ni dans .env
#
# En production :
#   - Configurer ces variables dans Vercel (Project Settings → Environment Variables)
#   - Ou dans GitHub Actions (Settings → Secrets and variables → Actions)
#
# En local : copier ce fichier vers `.env.local` et remplir les vraies valeurs.
#            Le fichier `.env.local` est ignoré par git.
# ============================================================================

VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=votre_anon_key
VITE_SUPABASE_PROJECT_ID=votre_project_id
VITE_APP_URL=https://insurezenflow.com